<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Contenido principal -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F5F5">

        <!-- Top bar -->
        <LinearLayout
            android:id="@+id/layoutTopBar"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#43A047"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageButton
                android:id="@+id/btnMenuHamburger"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_menu_hamburger"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Abrir menú"
                android:scaleType="centerInside"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="TIENDA"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

        <!-- Header: categorías + buscador -->
        <LinearLayout
            android:id="@+id/layoutHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/layoutTopBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCategorias"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clipToPadding="false"/>

            <ImageButton
                android:id="@+id/btnToggleBuscar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_search"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Buscar producto"/>

        </LinearLayout>

        <!-- Barra de búsqueda (oculta por defecto) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardBuscar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/layoutHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/etBuscarTienda"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:hint="Buscar producto..."
                android:textColor="#212121"
                android:textColorHint="#9E9E9E"
                android:background="@android:color/transparent"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:singleLine="true"/>

        </androidx.cardview.widget.CardView>

        <!-- Grid de productos -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvProductosTienda"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="4dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:paddingBottom="4dp"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/cardBuscar"
            app:layout_constraintBottom_toTopOf="@id/layoutCarrito"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Mensaje cuando no hay productos -->
        <TextView
            android:id="@+id/tvSinProductos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No hay productos disponibles"
            android:textSize="14sp"
            android:textColor="#9E9E9E"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="@id/rvProductosTienda"
            app:layout_constraintBottom_toBottomOf="@id/rvProductosTienda"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Barra del carrito (abajo) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/layoutCarrito"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#E8F5E9"
            app:cardCornerRadius="0dp"
            app:cardElevation="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvCarrito"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="60dp"/>

                    <TextView
                        android:id="@+id/tvCarritoVacio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="Carrito vacío"
                        android:textSize="13sp"
                        android:textColor="#9E9E9E"
                        android:textStyle="italic"/>

                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:background="#43A047"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:id="@+id/tvTotalTienda"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOTAL = $0.00 MXN"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <Button
                        android:id="@+id/btnRealizarVenta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Realizar"
                        android:textAllCaps="false"
                        android:textColor="#43A047"
                        android:backgroundTint="#FFFFFF"
                        android:minHeight="36dp"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Menú lateral deslizable -->
    <LinearLayout
        android:id="@+id/navDrawer"
        android:layout_width="220dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#000000"
        android:fitsSystemWindows="true">

        <!-- Header: MENU -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MENU"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            android:background="#1565C0"/>

        <!-- INVENTARIO -->
        <TextView
            android:id="@+id/menuInventario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="INVENTARIO"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:background="#388E3C"
            android:foreground="?attr/selectableItemBackground"/>

        <!-- Historial de ventas -->
        <TextView
            android:id="@+id/menuHistorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Historial de\nventas"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:background="#FF8F00"
            android:foreground="?attr/selectableItemBackground"/>

        <!-- Proveedores -->
        <TextView
            android:id="@+id/menuProveedores"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Proveedores"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:background="#CE93D8"
            android:foreground="?attr/selectableItemBackground"/>

        <!-- Fiados a clientes -->
        <TextView
            android:id="@+id/menuFiados"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fiados a\nclientes"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:background="#E53935"
            android:foreground="?attr/selectableItemBackground"/>

        <!-- Ajustes -->
        <TextView
            android:id="@+id/menuAjustes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ajustes"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:background="#7B1FA2"
            android:foreground="?attr/selectableItemBackground"/>

        <!-- Espaciador flexible -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#FFFFFF"/>

        <!-- Marca de agua: GerardoA. -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GerardoA."
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#424242"
            android:gravity="center"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:background="#FFFFFF"/>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>