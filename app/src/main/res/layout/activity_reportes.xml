<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Tarjeta resumen general -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardResumen"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvTituloResumen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resumen del inventario"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#212121"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <!-- Fila de 3 métricas superiores -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/filaMetricas"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/tvTituloResumen"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Métrica 1: Total productos -->
                <LinearLayout
                    android:id="@+id/metrica1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#E8F5E9"
                    android:padding="12dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/metrica2"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:id="@+id/tvTotalProductos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#2E7D32"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Productos"
                        android:textSize="12sp"
                        android:textColor="#388E3C"/>

                </LinearLayout>

                <!-- Métrica 2: Valor total venta -->
                <LinearLayout
                    android:id="@+id/metrica2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#E3F2FD"
                    android:padding="12dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintStart_toEndOf="@id/metrica1"
                    app:layout_constraintEnd_toStartOf="@id/metrica3"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:id="@+id/tvValorTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1565C0"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Valor venta"
                        android:textSize="12sp"
                        android:textColor="#1976D2"/>

                </LinearLayout>

                <!-- Métrica 3: Stock bajo -->
                <LinearLayout
                    android:id="@+id/metrica3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#FFEBEE"
                    android:padding="12dp"
                    app:layout_constraintStart_toEndOf="@id/metrica2"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:id="@+id/tvStockBajoCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#C62828"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stock bajo"
                        android:textSize="12sp"
                        android:textColor="#E53935"/>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Fila de 2 métricas de precios -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/filaPrecios"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/filaMetricas"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Métrica 4: Valor total compra -->
                <LinearLayout
                    android:id="@+id/metrica4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#FFF3E0"
                    android:padding="12dp"
                    android:layout_marginEnd="4dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/metrica5"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:id="@+id/tvValorCompra"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#E65100"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Inversión compra"
                        android:textSize="12sp"
                        android:textColor="#F57C00"/>

                </LinearLayout>

                <!-- Métrica 5: Ganancia potencial -->
                <LinearLayout
                    android:id="@+id/metrica5"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#F3E5F5"
                    android:padding="12dp"
                    android:layout_marginStart="4dp"
                    app:layout_constraintStart_toEndOf="@id/metrica4"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:id="@+id/tvGanancia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#6A1B9A"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ganancia potencial"
                        android:textSize="12sp"
                        android:textColor="#7B1FA2"/>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

    <!-- Título sección stock bajo -->
    <TextView
        android:id="@+id/tvTituloStockBajo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="15dp"
        android:text="Productos con stock bajo"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#C62828"
        app:layout_constraintTop_toBottomOf="@id/cardResumen"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Contenedor del Fragment -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloStockBajo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>